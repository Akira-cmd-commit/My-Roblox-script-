local UIManager = {}
UIManager.__index = UIManager

function UIManager.new()
    local self = setmetatable({}, UIManager)
    
    self.Maid = Maid.new()
    self.ScreenGui = nil
    self.Modules = {}
    self.Theme = {
        Primary = Color3.fromRGB(30, 30, 35),
        Secondary = Color3.fromRGB(45, 45, 55),
        Accent = Color3.fromRGB(88, 101, 242),
        Text = Color3.fromRGB(255, 255, 255),
        Success = Color3.fromRGB(46, 204, 113),
        Warning = Color3.fromRGB(241, 196, 15),
        Error = Color3.fromRGB(231, 76, 60)
    }
    
    self:Init()
    return self
end

function UIManager:Init()
    -- Create main ScreenGui with anti-detection measures
    self.ScreenGui = Instance.new("ScreenGui")
    self.ScreenGui.Name = HttpService:GenerateGUID(false)
    self.ScreenGui.ResetOnSpawn = false
    self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    self.ScreenGui.DisplayOrder = 999999
    
    -- Parent to CoreGui for persistence (requires executor)
    pcall(function()
        self.ScreenGui.Parent = game:GetService("CoreGui")
    end)
    
    if not self.ScreenGui.Parent then
        self.ScreenGui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    end
    
    self.Maid:GiveTask(self.ScreenGui)
    
    -- Create main container
    self.MainFrame = self:CreateElement("Frame", {
        Name = "MainContainer",
        Size = UDim2.new(0, 600, 0, 400),
        Position = UDim2.new(0.5, -300, 0.5, -200),
        BackgroundColor3 = self.Theme.Primary,
        BorderSizePixel = 0,
        Parent = self.ScreenGui
    })
    
    -- Add rounded corners
    self:CreateElement("UICorner", {
        CornerRadius = UDim.new(0, 8),
        Parent = self.MainFrame
    })
    
    -- Add shadow
    self:CreateShadow(self.MainFrame)
    
    -- Make draggable
    self:MakeDraggable(self.MainFrame)
    
    -- Initialize tab system
    self:InitTabSystem()
end

function UIManager:CreateElement(className, properties)
    local element = Instance.new(className)
    for prop, value in pairs(properties) do
        element[prop] = value
    end
    return element
end

function UIManager:CreateShadow(parent)
    local shadow = self:CreateElement("ImageLabel", {
        Name = "Shadow",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 4),
        Size = UDim2.new(1, 24, 1, 24),
        BackgroundTransparency = 1,
        Image = "rbxassetid://1316045217", -- Shadow asset
        ImageColor3 = Color3.new(0, 0, 0),
        ImageTransparency = 0.6,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(10, 10, 118, 118),
        ZIndex = -1,
        Parent = parent
    })
    return shadow
end

function UIManager:MakeDraggable(frame)
    local dragging = false
    local dragInput, dragStart, startPos
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale, 
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

function UIManager:InitTabSystem()
    self.TabContainer = self:CreateElement("Frame", {
        Name = "TabBar",
        Size = UDim2.new(0, 120, 1, -40),
        Position = UDim2.new(0, 0, 0, 40),
        BackgroundColor3 = self.Theme.Secondary,
        BorderSizePixel = 0,
        Parent = self.MainFrame
    })
    
    self:CreateElement("UICorner", {
        CornerRadius = UDim.new(0, 8),
        Parent = self.TabContainer
    })
    
    self.ContentContainer = self:CreateElement("Frame", {
        Name = "Content",
        Size = UDim2.new(1, -130, 1, -50),
        Position = UDim2.new(0, 125, 0, 45),
        BackgroundTransparency = 1,
        Parent = self.MainFrame
    })
    
    self.Tabs = {}
    self.ActiveTab = nil
end

function UIManager:AddTab(name, icon)
    local tabButton = self:CreateElement("TextButton", {
        Name = name .. "Tab",
        Size = UDim2.new(1, -10, 0, 35),
        Position = UDim2.new(0, 5, 0, 10 + (#self.Tabs * 40)),
        BackgroundColor3 = self.Theme.Primary,
        Text = name,
        TextColor3 = self.Theme.Text,
        Font = Enum.Font.GothamSemibold,
        TextSize = 14,
        Parent = self.TabContainer
    })
    
    self:CreateElement("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = tabButton
    })
    
    local contentFrame = self:CreateElement("ScrollingFrame", {
        Name = name .. "Content",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = self.Theme.Accent,
        Visible = false,
        Parent = self.ContentContainer
    })
    
    self:CreateElement("UIListLayout", {
        Padding = UDim.new(0, 10),
        Parent = contentFrame
    })
    
    local tab = {
        Button = tabButton,
        Content = contentFrame,
        Name = name
    }
    
    tabButton.MouseButton1Click:Connect(function()
        self:SwitchTab(tab)
    end)
    
    table.insert(self.Tabs, tab)
    
    if #self.Tabs == 1 then
        self:SwitchTab(tab)
    end
    
    return contentFrame
end

function UIManager:SwitchTab(tab)
    if self.ActiveTab == tab then return end
    
    if self.ActiveTab then
        self.ActiveTab.Content.Visible = false
        self.ActiveTab.Button.BackgroundColor3 = self.Theme.Primary
    end
    
    self.ActiveTab = tab
    tab.Content.Visible = true
    tab.Button.BackgroundColor3 = self.Theme.Accent
end

