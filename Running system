--[[
    NETWORK OWNERSHIP: Critical for manipulating physics
    Roblox uses network ownership to determine which client/server controls physics
]]

local NetworkSystem = {}
NetworkSystem.__index = NetworkSystem

function NetworkSystem.new()
    local self = setmetatable({}, NetworkSystem)
    self.Maid = Maid.new()
    self.OwnedParts = {}
    return self
end

--[[
    SetNetworkOwner: Attempts to claim network ownership of a part
    This allows client-side physics manipulation
]]

function NetworkSystem:ClaimOwnership(part)
    if not part:IsA("BasePart") then return false end
    
    -- Method 1: Direct ownership claim (requires exploits)
    local success = pcall(function()
        -- This only works with certain executors
        part:SetNetworkOwner(game:GetService("Players").LocalPlayer)
    end)
    
    if success then
        self.OwnedParts[part] = true
        return true
    end
    
    -- Method 2: Physics manipulation through velocity
    -- Even without ownership, rapid updates can desync
    return false
end

--[[
    Velocity Manipulation: "Netless" method
    Rapidly setting velocity can override server authority briefly
]]

function NetworkSystem:VelocityFly(part, speed)
    if not part then return end
    
    local connection
    connection = game:GetService("RunService").Heartbeat:Connect(function()
        if not part or not part.Parent then
            connection:Disconnect()
            return
        end
        
        -- Rapid velocity updates create "netless" state
        part.Velocity = Vector3.new(0, 0, 0)
        part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        
        -- Apply movement
        local camera = workspace.CurrentCamera
        local moveDir = Vector3.new()
        
        -- Get input and calculate
        local UIS = game:GetService("UserInputService")
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
        
        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit * speed
            part.CFrame = part.CFrame + (moveDir * 0.016) -- Delta time approximation
        end
    end)
    
    self.Maid:GiveTask(connection)
    return connection
end

--[[
    Desync Method: Create position desynchronization
    Server sees different position than client
]]

function NetworkSystem:CreateDesync(character)
    local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    local realPosition = humanoidRootPart.CFrame
    
    -- Store real position
    self.DesyncData = {
        RealCFrame = realPosition,
        FakeCFrame = realPosition,
        Enabled = true
    }
    
    -- Hook CFrame access
    local oldIndex
    oldIndex = hookmetamethod(game, "__index", function(self, key)
        if self == humanoidRootPart and key == "CFrame" and NetworkSystem.DesyncData.Enabled then
            return NetworkSystem.DesyncData.FakeCFrame
        end
        return oldIndex(self, key)
    end)
    
    -- Update loop
    self.Maid:GiveTask(game:GetService("RunService").Heartbeat:Connect(function()
        if not self.DesyncData.Enabled then return end
        
        -- Update fake position based on input
        -- Real position stays safe while fake position goes through walls
        self.DesyncData.FakeCFrame = self.DesyncData.FakeCFrame
    end))
end

--[[
    Remote Event Spoofing: Manipulate network traffic
]]

function NetworkSystem:HookRemotes()
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        -- Intercept FireServer calls
        if method == "FireServer" then
            local remote = self
            
            -- Log remote
            print("Remote Fired:", remote.Name, unpack(args))
            
            -- Modify args if needed
            -- args[1] = modifiedValue
            
            return oldNamecall(self, unpack(args))
        end
        
        return oldNamecall(self, ...)
    end)
    
    return oldNamecall
end

