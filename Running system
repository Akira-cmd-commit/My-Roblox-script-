--[[
    CHAMS: Wallhack visualization
    Shows players through walls using Highlight instances
]]

function VisualSystem:CreateChams(player, settings)
    settings = settings or {}
    local color = settings.Color or Color3.fromRGB(255, 0, 0)
    local transparency = settings.Transparency or 0.5
    
    local highlight = Instance.new("Highlight")
    highlight.Name = HttpService:GenerateGUID(false)
    highlight.FillColor = color
    highlight.OutlineColor = Color3.new(1, 1, 1)
    highlight.FillTransparency = transparency
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    
    -- Parent to character when it exists
    local function setupCharacter(char)
        if char then
            highlight.Parent = char
        end
    end
    
    if player.Character then
        setupCharacter(player.Character)
    end
    
    self.Maid:GiveTask(player.CharacterAdded:Connect(setupCharacter))
    self.Maid:GiveTask(highlight)
    
    self.Chams[player] = {
        Highlight = highlight,
        Settings = settings
    }
    
    return highlight
end

function VisualSystem:RemoveChams(player)
    if self.Chams[player] then
        self.Chams[player].Highlight:Destroy()
        self.Chams[player] = nil
    end
end

--[[
    TRACERS: Draw lines to targets
    Uses Drawing API or Beam instances
]]

function VisualSystem:CreateTracer(target, settings)
    settings = settings or {}
    
    -- Using Drawing API (more performant for 2D)
    local line = Drawing.new("Line")
    line.Visible = false
    line.Thickness = settings.Thickness or 1
    line.Color = settings.Color or Color3.fromRGB(255, 255, 255)
    line.Transparency = settings.Transparency or 1
    
    local tracer = {
        Line = line,
        Target = target,
        Settings = settings,
        Active = true
    }
    
    table.insert(self.Tracers, tracer)
    return tracer
end

function VisualSystem:UpdateTracers()
    local camera = workspace.CurrentCamera
    local viewportSize = camera.ViewportSize
    local centerScreen = Vector2.new(viewportSize.X / 2, viewportSize.Y)
    
    for _, tracer in ipairs(self.Tracers) do
        if not tracer.Active then
            tracer.Line.Visible = false
            continue
        end
        
        local targetPos = tracer.Target
        if typeof(targetPos) == "Instance" then
            if targetPos:IsA("Model") then
                targetPos = targetPos:GetPivot().Position
            elseif targetPos:IsA("BasePart") then
                targetPos = targetPos.Position
            end
        end
        
        local screenPos, onScreen = camera:WorldToViewportPoint(targetPos)
        
        if onScreen and screenPos.Z > 0 then
            tracer.Line.From = centerScreen
            tracer.Line.To = Vector2.new(screenPos.X, screenPos.Y)
            tracer.Line.Visible = true
        else
            tracer.Line.Visible = false
        end
    end
end

--[[
    SKELETON ESP: Draw bones on character rig
]]

function VisualSystem:CreateSkeleton(player, settings)
    settings = settings or {}
    local lines = {}
    local bones = {
        {"Head", "UpperTorso"},
        {"UpperTorso", "LowerTorso"},
        {"UpperTorso", "LeftUpperArm"},
        {"LeftUpperArm", "LeftLowerArm"},
        {"LeftLowerArm", "LeftHand"},
        {"UpperTorso", "RightUpperArm"},
        {"RightUpperArm", "RightLowerArm"},
        {"RightLowerArm", "RightHand"},
        {"LowerTorso", "LeftUpperLeg"},
        {"LeftUpperLeg", "LeftLowerLeg"},
        {"LeftLowerLeg", "LeftFoot"},
        {"LowerTorso", "RightUpperLeg"},
        {"RightUpperLeg", "RightLowerLeg"},
        {"RightLowerLeg", "RightFoot"}
    }
    
    for _, bone in ipairs(bones) do
        local line = Drawing.new("Line")
        line.Thickness = settings.Thickness or 1
        line.Color = settings.Color or Color3.fromRGB(255, 255, 255)
        line.Transparency = 1
        line.Visible = false
        table.insert(lines, {Line = line, Parts = bone})
    end
    
    local skeleton = {
        Lines = lines,
        Player = player,
        Settings = settings,
        Active = true
    }
    
    self.Skeletons[player] = skeleton
    return skeleton
end

function VisualSystem:UpdateSkeletons()
    local camera = workspace.CurrentCamera
    
    for player, skeleton in pairs(self.Skeletons) do
        if not skeleton.Active or not player.Character then
            for _, data in ipairs(skeleton.Lines) do
                data.Line.Visible = false
            end
            continue
        end
        
        for _, data in ipairs(skeleton.Lines) do
            local part1 = player.Character:FindFirstChild(data.Parts[1])
            local part2 = player.Character:FindFirstChild(data.Parts[2])
            
            if part1 and part2 then
                local pos1, vis1 = camera:WorldToViewportPoint(part1.Position)
                local pos2, vis2 = camera:WorldToViewportPoint(part2.Position)
                
                if vis1 and vis2 and pos1.Z > 0 and pos2.Z > 0 then
                    data.Line.From = Vector2.new(pos1.X, pos1.Y)
                    data.Line.To = Vector2.new(pos2.X, pos2.Y)
                    data.Line.Visible = true
                else
                    data.Line.Visible = false
                end
            else
                data.Line.Visible = false
            end
        end
    end
end

