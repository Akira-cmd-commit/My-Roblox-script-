--[[
    MAID PATTERN: Automatic cleanup system
    Prevents memory leaks by tracking connections and instances
]]

local Maid = {}
Maid.__index = Maid

function Maid.new()
    return setmetatable({
        _tasks = {},
        _isCleaning = false
    }, Maid)
end

function Maid:GiveTask(task)
    if self._isCleaning then return end
    
    local taskType = typeof(task)
    local cleanupFn
    
    if taskType == "RBXScriptConnection" then
        cleanupFn = function() task:Disconnect() end
    elseif taskType == "Instance" then
        cleanupFn = function() task:Destroy() end
    elseif taskType == "function" then
        cleanupFn = task
    elseif taskType == "table" and task.Destroy then
        cleanupFn = function() task:Destroy() end
    else
        error("Invalid task type: " .. taskType)
    end
    
    table.insert(self._tasks, cleanupFn)
    return #self._tasks
end

function Maid:Clean()
    self._isCleaning = true
    for _, task in ipairs(self._tasks) do
        task()
    end
    table._tasks = {}
    self._isCleaning = false
end

function Maid:Destroy()
    self:Clean()
    setmetatable(self, nil)
end

--[[
    SIGNAL SYSTEM: Custom event system with better control
    Alternative to BindableEvents with type safety
]]

local Signal = {}
Signal.__index = Signal

function Signal.new()
    return setmetatable({
        _connections = {},
        _yieldedThreads = {}
    }, Signal)
end

function Signal:Connect(callback)
    local connection = {
        Callback = callback,
        Connected = true,
        _signal = self
    }
    
    table.insert(self._connections, connection)
    
    return {
        Disconnect = function()
            connection.Connected = false
            for i, conn in ipairs(self._connections) do
                if conn == connection then
                    table.remove(self._connections, i)
                    break
                end
            end
        end
    }
end

function Signal:Fire(...)
    local args = {...}
    for _, connection in ipairs(self._connections) do
        if connection.Connected then
            task.spawn(function()
                connection.Callback(unpack(args))
            end)
        end
    end
    
    -- Resume yielded threads
    for thread, _ in pairs(self._yieldedThreads) do
        task.spawn(thread, ...)
    end
    self._yieldedThreads = {}
end

function Signal:Wait()
    local thread = coroutine.running()
    self._yieldedThreads[thread] = true
    return coroutine.yield()
end

function Signal:Destroy()
    for _, connection in ipairs(self._connections) do
        connection.Connected = false
    end
    self._connections = {}
    self._yieldedThreads = {}
end

