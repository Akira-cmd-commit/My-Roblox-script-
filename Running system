--[[
    Name Obfuscation: Randomize instance names to avoid detection
]]

function StealthSystem:ObfuscateNames()
    local function randomString(length)
        local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
        local str = ""
        for i = 1, length do
            str = str .. chars:sub(math.random(1, #chars))
        end
        return str
    end
    
    -- Hook instance creation
    local oldInstanceNew = Instance.new
    Instance.new = function(className, parent)
        local instance = oldInstanceNew(className)
        instance.Name = randomString(16)
        if parent then
            instance.Parent = parent
        end
        return instance
    end
end

--[[
    Anti-Detection: Hook detection methods
]]

function StealthSystem:InitAntiDetection()
    -- Hook getconnections to hide our connections
    local oldGetConnections = getconnections
    if oldGetConnections then
        getconnections = function(signal)
            local connections = oldGetConnections(signal)
            local filtered = {}
            
            for _, conn in ipairs(connections) do
                -- Filter out our connections
                if not conn.Function or not tostring(conn.Function):find("Maid") then
                    table.insert(filtered, conn)
                end
            end
            
            return filtered
        end
    end
    
    -- Hook hookfunction detection
    local detectedHooks = {}
    local oldHookFunction = hookfunction
    hookfunction = function(original, hook)
        detectedHooks[original] = hook
        return oldHookFunction(original, hook)
    end
    
    -- Spoof runtime info
    local oldGetReg = getreg
    if oldGetReg then
        getreg = function()
            local registry = oldGetReg()
            -- Filter our entries
            local cleaned = {}
            for i, v in pairs(registry) do
                if type(v) ~= "table" or not v._isScript then
                    cleaned[i] = v
                end
            end
            return cleaned
        end
    end
end

--[[
    Behavior Humanization: Add randomness and natural patterns
]]

function StealthSystem:InitHumanization()
    self.Humanization = {
        ReactionDelay = {min = 0.05, max = 0.15},
        AimJitter = 2, -- pixels
        MovementNoise = 0.1
    }
    
    -- Randomize timing
    function self:HumanizedDelay()
        local delay = math.random() * (self.Humanization.ReactionDelay.max - self.Humanization.ReactionDelay.min) 
                      + self.Humanization.ReactionDelay.min
        task.wait(delay)
    end
    
    -- Add jitter to precise values
    function self:AddJitter(value, amount)
        amount = amount or self.Humanization.AimJitter
        return value + (math.random() - 0.5) * amount
    end
end

--[[
    Signature Masking: Hide from signature-based detection
]]

function StealthSystem:MaskSignatures()
    -- Randomize script patterns
    local function polymorphicCode(code)
        local obfuscated = code
        
        -- Variable name randomization
        local varMap = {}
        obfuscated = obfuscated:gsub("local%s+([%w_]+)", function(var)
            if not varMap[var] then
                varMap[var] = "_" .. tostring(math.random(100000, 999999))
            end
            return "local " .. varMap[var]
        end)
        
        -- String obfuscation
        obfuscated = obfuscated:gsub("\"([^\"]+)\"", function(str)
            local charCodes = {}
            for i = 1, #str do
                table.insert(charCodes, string.byte(str, i))
            end
            return "string.char(" .. table.concat(charCodes, ",") .. ")"
        end)
        
        return obfuscated
    end
    
    self.PolymorphicCode = polymorphicCode
end

