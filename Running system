local StateManager = {}
StateManager.__index = StateManager

function StateManager.new()
    local self = setmetatable({}, StateManager)
    self.States = {}
    self.Transitions = {}
    self.CurrentState = nil
    self.OnStateChanged = Signal.new()
    
    return self
end

function StateManager:AddState(name, stateData)
    self.States[name] = {
        OnEnter = stateData.OnEnter or function() end,
        OnExit = stateData.OnExit or function() end,
        OnUpdate = stateData.OnUpdate or function() end,
        Transitions = stateData.Transitions or {},
        Data = stateData.Data or {}
    }
end

function StateManager:TransitionTo(newState, ...)
    if self.CurrentState == newState then return end
    if not self.States[newState] then error("State does not exist: " .. newState) end
    
    -- Exit current
    if self.CurrentState then
        self.States[self.CurrentState].OnExit()
    end
    
    -- Enter new
    local oldState = self.CurrentState
    self.CurrentState = newState
    self.States[newState].OnEnter(...)
    
    self.OnStateChanged:Fire(oldState, newState)
end

function StateManager:Update(deltaTime)
    if not self.CurrentState then return end
    
    local state = self.States[self.CurrentState]
    state.OnUpdate(deltaTime)
    
    -- Check transitions
    for condition, targetState in pairs(state.Transitions) do
        if condition() then
            self:TransitionTo(targetState)
            break
        end
    end
end

--[[
    GOVERNOR: Performance and safety regulator
]]

local Governor = {}
Governor.__index = Governor

function Governor.new()
    local self = setmetatable({}, Governor)
    self.Stats = {
        FPS = 0,
        Memory = 0,
        Ping = 0,
        FrameTime = 0
    }
    self.Limits = {
        MaxFPS = 240,
        MaxMemoryMB = 512,
        TargetFrameTime = 1/60
    }
    self.Throttling = false
    self.Maid = Maid.new()
    
    self:InitMonitoring()
    return self
end

function Governor:InitMonitoring()
    local lastTime = tick()
    local frameCount = 0
    
    self.Maid:GiveTask(game:GetService("RunService").Heartbeat:Connect(function()
        local currentTime = tick()
        frameCount = frameCount + 1
        
        if currentTime - lastTime >= 1 then
            self.Stats.FPS = frameCount
            self.Stats.FrameTime = (currentTime - lastTime) / frameCount
            frameCount = 0
            lastTime = currentTime
            
            -- Check memory
            self.Stats.Memory = collectgarbage("count") / 1024
            
            -- Adaptive throttling
            self:CheckLimits()
        end
    end))
end

function Governor:CheckLimits()
    local shouldThrottle = false
    
    if self.Stats.FPS < 30 then
        shouldThrottle = true
    end
    
    if self.Stats.Memory > self.Limits.MaxMemoryMB then
        collectgarbage("collect")
        shouldThrottle = true
    end
    
    if shouldThrottle ~= self.Throttling then
        self.Throttling = shouldThrottle
        self:OnThrottleChanged(shouldThrottle)
    end
end

function Governor:OnThrottleChanged(throttling)
    -- Reduce feature quality when throttling
    if throttling then
        print("Governor: Throttling enabled for performance")
        -- Disable expensive features
    else
        print("Governor: Throttling disabled")
    end
end

