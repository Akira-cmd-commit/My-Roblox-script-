local ESPSystem = {}
ESPSystem.__index = ESPSystem

function ESPSystem.new()
    local self = setmetatable({}, ESPSystem)
    self.Maid = Maid.new()
    self.ESPObjects = {}
    self.Settings = {
        Enabled = true,
        TeamCheck = true,
        MaxDistance = 1000,
        ShowName = true,
        ShowDistance = true,
        ShowHealth = true,
        ShowBox = true,
        ShowTracer = true,
        ShowSkeleton = false,
        TextSize = 13,
        TextFont = Drawing.Fonts.UI,
        BoxColor = Color3.fromRGB(255, 0, 0),
        VisibleColor = Color3.fromRGB(0, 255, 0),
        HiddenColor = Color3.fromRGB(255, 0, 0)
    }
    
    self:Init()
    return self
end

function ESPSystem:Init()
    -- Update loop
    self.Maid:GiveTask(game:GetService("RunService").RenderStepped:Connect(function()
        self:Update()
    end))
    
    -- Handle new players
    local players = game:GetService("Players")
    
    for _, player in ipairs(players:GetPlayers()) do
        if player ~= players.LocalPlayer then
            self:AddPlayer(player)
        end
    end
    
    self.Maid:GiveTask(players.PlayerAdded:Connect(function(player)
        self:AddPlayer(player)
    end))
    
    self.Maid:GiveTask(players.PlayerRemoving:Connect(function(player)
        self:RemovePlayer(player)
    end))
end

function ESPSystem:AddPlayer(player)
    if self.ESPObjects[player] then return end
    
    local esp = {
        Player = player,
        Drawings = {},
        Connections = {}
    }
    
    -- Create drawings
    if self.Settings.ShowBox then
        esp.Drawings.Box = Drawing.new("Square")
        esp.Drawings.Box.Thickness = 1
        esp.Drawings.Box.Filled = false
        esp.Drawings.Box.Visible = false
    end
    
    if self.Settings.ShowName then
        esp.Drawings.Name = Drawing.new("Text")
        esp.Drawings.Name.Center = true
        esp.Drawings.Name.Outline = true
        esp.Drawings.Name.Size = self.Settings.TextSize
        esp.Drawings.Name.Font = self.Settings.TextFont
        esp.Drawings.Name.Visible = false
    end
    
    if self.Settings.ShowDistance then
        esp.Drawings.Distance = Drawing.new("Text")
        esp.Drawings.Distance.Center = true
        esp.Drawings.Distance.Outline = true
        esp.Drawings.Distance.Size = self.Settings.TextSize - 2
        esp.Drawings.Distance.Font = self.Settings.TextFont
        esp.Drawings.Distance.Visible = false
    end
    
    if self.Settings.ShowHealth then
        esp.Drawings.HealthBar = Drawing.new("Square")
        esp.Drawings.HealthBar.Thickness = 1
        esp.Drawings.HealthBar.Filled = true
        esp.Drawings.HealthBar.Visible = false
        
        esp.Drawings.HealthBarBackground = Drawing.new("Square")
        esp.Drawings.HealthBarBackground.Thickness = 1
        esp.Drawings.HealthBarBackground.Filled = true
        esp.Drawings.HealthBarBackground.Color = Color3.fromRGB(0, 0, 0)
        esp.Drawings.HealthBarBackground.Visible = false
    end
    
    if self.Settings.ShowTracer then
        esp.Drawings.Tracer = Drawing.new("Line")
        esp.Drawings.Tracer.Thickness = 1
        esp.Drawings.Tracer.Visible = false
    end
    
    self.ESPObjects[player] = esp
end

function ESPSystem:RemovePlayer(player)
    local esp = self.ESPObjects[player]
    if not esp then return end
    
    for _, drawing in pairs(esp.Drawings) do
        drawing:Remove()
    end
    
    for _, conn in ipairs(esp.Connections) do
        conn:Disconnect()
    end
    
    self.ESPObjects[player] = nil
end

function ESPSystem:Update()
    if not self.Settings.Enabled then
        for _, esp in pairs(self.ESPObjects) do
            for _, drawing in pairs(esp.Drawings) do
                drawing.Visible = false
            end
        end
        return
    end
    
    local localPlayer = game:GetService("Players").LocalPlayer
    local camera = workspace.CurrentCamera
    local viewportSize = camera.ViewportSize
    
    for player, esp in pairs(self.ESPObjects) do
        local character = player.Character
        if not character then
            for _, drawing in pairs(esp.Drawings) do
                drawing.Visible = false
            end
            continue
        end
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        local head = character:FindFirstChild("Head")
        
        if not humanoid or not rootPart or not head then
            for _, drawing in pairs(esp.Drawings) do
                drawing.Visible = false
            end
            continue
        end
        
        -- Team check
        if self.Settings.TeamCheck and player.Team == localPlayer.Team then
            for _, drawing in pairs(esp.Drawings) do
                drawing.Visible = false
            end
            continue
        end
        
        -- Distance check
        local distance = (rootPart.Position - camera.CFrame.Position).Magnitude
        if distance > self.Settings.MaxDistance then
            for _, drawing in pairs(esp.Drawings) do
                drawing.Visible = false
            end
            continue
        end
        
        -- Calculate box bounds
        local headPos, headOnScreen = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local rootPos, rootOnScreen = camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
        
        if not headOnScreen or not rootOnScreen then
            for _, drawing in pairs(esp.Drawings) do
                drawing.Visible = false
            end
            continue
        end
        
        local boxHeight = math.abs(headPos.Y - rootPos.Y)
        local boxWidth = boxHeight * 0.6
        
        local boxPosition = Vector2.new(
            math.floor(rootPos.X - boxWidth / 2),
            math.floor(headPos.Y)
        )
        
        -- Update visibility check
        local isVisible = self:IsVisible(head)
        local color = isVisible and self.Settings.VisibleColor or self.Settings.HiddenColor
        
        -- Update box
        if esp.Drawings.Box then
            esp.Drawings.Box.Size = Vector2.new(boxWidth, boxHeight)
            esp.Drawings.Box.Position = boxPosition
            esp.Drawings.Box.Color = color
            esp.Drawings.Box.Visible = true
        end
        
        -- Update name
        if esp.Drawings.Name then
            esp.Drawings.Name.Text = player.Name
            esp.Drawings.Name.Position = Vector2.new(boxPosition.X + boxWidth / 2, boxPosition.Y - 15)
            esp.Drawings.Name.Color = color
            esp.Drawings.Name.Visible = true
        end
        
        -- Update distance
        if esp.Drawings.Distance then
            esp.Drawings.Distance.Text = math.floor(distance) .. "m"
            esp.Drawings.Distance.Position = Vector2.new(boxPosition.X + boxWidth / 2, boxPosition.Y + boxHeight + 2)
            esp.Drawings.Distance.Color = color
            esp.Drawings.Distance.Visible = true
        end
        
        -- Update health bar
        if esp.Drawings.HealthBar and esp.Drawings.HealthBarBackground then
            local healthPercent = humanoid.Health / humanoid.MaxHealth
            local barHeight = boxHeight * healthPercent
            
            esp.Drawings.HealthBarBackground.Size = Vector2.new(4, boxHeight)
            esp.Drawings.HealthBarBackground.Position = Vector2.new(boxPosition.X - 8, boxPosition.Y)
            esp.Drawings.HealthBarBackground.Visible = true
            
            esp.Drawings.HealthBar.Size = Vector2.new(2, barHeight)
            esp.Drawings.HealthBar.Position = Vector2.new(boxPosition.X - 7, boxPosition.Y + boxHeight - barHeight)
            esp.Drawings.HealthBar.Color = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
            esp.Drawings.HealthBar.Visible = true
        end
        
        -- Update tracer
        if esp.Drawings.Tracer then
            local tracerOrigin = Vector2.new(viewportSize.X / 2, viewportSize.Y)
            esp.Drawings.Tracer.From = tracerOrigin
            esp.Drawings.Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            esp.Drawings.Tracer.Color = color
            esp.Drawings.Tracer.Visible = true
        end
    end
end

function ESPSystem:IsVisible(targetPart)
    local camera = workspace.CurrentCamera
    local origin = camera.CFrame.Position
    local direction = (targetPart.Position - origin).Unit * (targetPart.Position - origin).Magnitude
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {game:GetService("Players").LocalPlayer.Character}
    
    local result = workspace:Raycast(origin, direction, raycastParams)
    return not result or result.Instance:IsDescendantOf(targetPart.Parent)
end

